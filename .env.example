NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this in client code and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.0-flash.
GEMINI_MODEL=

# Server-only. Used by future OpenAI provider. Never expose in client code.
OPENAI_API_KEY=

# Optional future OpenAI provider model. Not used by the current Gemini-only MVP.
OPENAI_MODEL=

# Required for the weekly scan cron route (app/api/cron/weekly-scans). Vercel
# sends this as `Authorization: Bearer <CRON_SECRET>`. Server-only.
CRON_SECRET=

# Kill switch for automated recurring scans. Defaults to disabled (any value
# other than "true" disables the cron route's scan logic).
CRON_SCANS_ENABLED=

# Optional. Caps how many projects the weekly cron processes per run. Defaults to 5.
MAX_PROJECTS_PER_CRON_RUN=
